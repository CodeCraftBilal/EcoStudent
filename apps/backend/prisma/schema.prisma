generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  userId                                Int              @id @default(autoincrement()) @map("userid")
  userName                              String           @map("username") @db.VarChar(255)
  email                                 String           @unique @db.VarChar(255)
  role                                  ROLE?
  status                                USER_STATUS      @default(ACTIVE)
  hashedPassword                        String?          @map("hashedpassword") @db.VarChar(255)
  hashedRefreshToken                    String?          @map("hashedrefreshtoken") @db.VarChar(255)
  phoneNumber                           String?          @map("phonenumber") @db.VarChar(25)
  profilePicture                        String?          @map("profilepicture") @db.VarChar(255)
  userLocation                          String?          @map("userlocation") @db.VarChar(255)
  latitude                              Decimal?         @db.Decimal(10, 8)
  longitude                             Decimal?         @db.Decimal(11, 8)
  rating                                Decimal?         @db.Decimal(3, 2)
  isVerified                            Boolean?         @map("isverified")
  createdAt                             DateTime?        @map("created_at") @db.Timestamp(6)
  updatedAt                             DateTime?        @map("updated_at") @db.Timestamp(6)
  tokenversion                          Int              @default(0)
  isOnline                              Boolean?         @default(false) @map("isonline")
  messagesReceived                      Message[]        @relation("Message_receiveridTousers")
  messagesSent                          Message[]        @relation("Message_senderidTousers")
  chat_chat_receiveridTousers           chat[]           @relation("chat_receiveridTousers")
  chat_chat_senderidTousers             chat[]           @relation("chat_senderidTousers")
  exchanges                             exchanges[]
  notifications                         notifications[]
  product                               product[]
  reviews_reviews_revieweduseridTousers reviews[]        @relation("reviews_revieweduseridTousers")
  reviews_reviews_revieweridTousers     reviews[]        @relation("reviews_revieweridTousers")
  search_history                        search_history[]
  user_favorites                        user_favorites[]

  @@map("users")
}

model Message {
  messageId    Int            @id @default(autoincrement()) @map("messageid")
  chatId       Int            @map("chatid")
  senderId     Int            @map("senderid")
  receiverId   Int            @map("receiverid")
  messageType  message_type   @map("messagetype")
  content      String         @db.VarChar(1000)
  voiceNoteUrl String?        @map("voicenoteurl") @db.VarChar(255)
  isRead       Boolean        @default(false) @map("isread")
  createdAt    DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  status       MESSAGE_STATUS @default(sent)
  chat         chat           @relation(fields: [chatId], references: [chatId], onDelete: NoAction, onUpdate: NoAction, map: "fk_message_chat")
  receiver     Users          @relation("Message_receiveridTousers", fields: [receiverId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_message_receiver")
  sender       Users          @relation("Message_senderidTousers", fields: [senderId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_message_sender")

  @@map("Message")
}

model admin {
  admin_id Int @id
}

model category {
  categoryId       Int        @id @default(autoincrement()) @map("categoryid")
  parentCategoryId Int?       @map("parentcategoryid")
  categoryName     String     @unique(map: "uniquename") @map("categoryname") @db.VarChar(255)
  description      String?
  mediaPath        String?    @map("mediapath") @db.VarChar(255)
  createdAt        DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  category         category?  @relation("categoryTocategory", fields: [parentCategoryId], references: [categoryId], onDelete: NoAction, onUpdate: NoAction, map: "fk_category_parent")
  other_category   category[] @relation("categoryTocategory")
  product          product[]
}

model chat {
  chatId                       Int       @id @default(autoincrement()) @map("chatid")
  senderId                     Int       @map("senderid")
  receiverId                   Int       @map("receiverid")
  productId                    Int       @map("productid")
  lastMessage                  String?   @map("lastmessage") @db.VarChar(255)
  lastMessageAt                DateTime? @map("lastmessage_at") @db.Timestamp(6)
  createdAt                    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  messages                     Message[]
  product                      product   @relation(fields: [productId], references: [productId], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_product")
  users_chat_receiveridTousers Users     @relation("chat_receiveridTousers", fields: [receiverId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_receiver")
  users_chat_senderidTousers   Users     @relation("chat_senderidTousers", fields: [senderId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_sender")

  @@unique([senderId, receiverId, productId], name: "senderid_receiverid_productid_unique", map: "chat_senderid_receiverid_unique")
}

model exchanges {
  exchangeId      Int              @id @default(autoincrement()) @map("exchangeid")
  productId       Int              @map("productid")
  buyerId         Int              @map("buyerid")
  exchangeType    exchange_type    @map("exchangetype")
  status          exchange_status? @default(pending)
  agreedPrice     Decimal          @map("agreedprice") @db.Decimal(10, 2)
  meetupLocation  String           @map("meetuplocation") @db.VarChar(255)
  meetupLatitude  Decimal          @map("meetuplatitude") @db.Decimal(10, 8)
  meetupLongitude Decimal          @map("meetuplongitude") @db.Decimal(11, 8)
  meetupTime      DateTime         @map("meetuptime") @db.Timestamp(6)
  completedAt     DateTime?        @map("completed_at") @db.Timestamp(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  users           Users            @relation(fields: [buyerId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_exchanges_buyer")
  product         product          @relation(fields: [productId], references: [productId], onDelete: NoAction, onUpdate: NoAction, map: "fk_exchanges_product")
  reviews         reviews[]
}

model notifications {
  notificationId    Int               @id @default(autoincrement()) @map("notificationid")
  title             String            @db.VarChar(255)
  message           String            @db.VarChar(255)
  isRead            Boolean?          @default(false) @map("isread")
  relatedEntityType String?           @map("relatedentitytype") @db.VarChar(50)
  relatedEntityId   Int?              @map("relatedentityid")
  createdAt         DateTime?         @default(now()) @map("created_at") @db.Timestamp(6)
  userId            Int               @map("userid")
  type              NOTIFICATION_TYPE
  users             Users             @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_notifications_users")
}

model product {
  productId        Int                      @id @default(autoincrement()) @map("productid")
  userId           Int                      @map("userid")
  categoryId       Int                      @map("categoryid")
  title            String                   @db.VarChar(255)
  description      String?
  price            Decimal                  @db.Decimal(10, 2)
  images           Json?                    @db.Json
  viewCount        Int?                     @default(0) @map("viewcount")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime                 @default(now()) @map("updated_at") @db.Timestamp(6)
  originalPrice    Int?                     @map("originalprice")
  productCondition product_condition        @map("productcondition")
  productType      product_type             @map("producttype")
  exchangeType     exchange_type            @default(sale) @map("exchangetype")
  status           PRODUCT_STATUS           @default(active)
  embedding        Unsupported("vector")?
  search_vector    Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, (((COALESCE(title, ''::character varying))::text || ' '::text) || COALESCE(description, ''::text)))"))
  chat             chat[]
  exchanges        exchanges[]
  category         category                 @relation(fields: [categoryId], references: [categoryId], onDelete: NoAction, onUpdate: NoAction, map: "fk_product_category")
  users            Users                    @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_product_users")
  userFavorites    user_favorites[]

  @@index([embedding])
}

model reviews {
  reviewid                            Int        @id @default(autoincrement())
  exchangeId                          Int?       @map("exchangeid")
  reviewerid                          Int?
  revieweduserid                      Int?
  rating                              Int?
  comment                             String?    @db.VarChar(500)
  created_at                          DateTime?  @db.Timestamp(6)
  exchanges                           exchanges? @relation(fields: [exchangeId], references: [exchangeId], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviews_exchange")
  users_reviews_revieweduseridTousers Users?     @relation("reviews_revieweduseridTousers", fields: [revieweduserid], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviews_revieweduser")
  users_reviews_revieweridTousers     Users?     @relation("reviews_revieweridTousers", fields: [reviewerid], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviews_reviewer")
}

model search_history {
  searchid   Int       @id @default(autoincrement())
  userid     Int
  query      String?   @db.VarChar(255)
  created_at DateTime? @db.Timestamp(6)
  users      Users     @relation(fields: [userid], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_searchhistory_users")
}

model user_favorites {
  favoriteId Int       @id @default(autoincrement()) @map("favoriteid")
  userId     Int       @map("userid")
  productId  Int       @map("productid")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  product    product   @relation(fields: [productId], references: [productId], onDelete: NoAction, onUpdate: NoAction, map: "fk_userfavorites_product")
  users      Users     @relation(fields: [userId], references: [userId], onDelete: NoAction, onUpdate: NoAction, map: "fk_userfavorites_users")

  @@unique([userId, productId], map: "user_favorites_userid_productid_unique")
}

enum ROLE {
  GUEST
  USER
  ADMIN
}

enum exchange_status {
  pending
  accepted
  completed
  cancelled
}

enum exchange_type {
  sale
  exchange
  donation
}

enum message_type {
  TEXT
  VOICE
}

enum product_type {
  books
  bags
  uniform
  calculator
  geometry
  other
}

enum product_condition {
  excellent
  good
  fair
}

enum status {
  active
  sold
  reserved
  draft
}

enum PRODUCT_STATUS {
  active
  sold
  reserved
  draft
}

enum NOTIFICATION_TYPE {
  message
  sale
  review
  purchase
  listing
  order
  other
}

enum MESSAGE_STATUS {
  sent
  delivered
  read
}

enum USER_STATUS {
  ACTIVE
  SUSPENDED
  DELETED
}
